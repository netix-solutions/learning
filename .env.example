# Copy to .env.local and fill in. For local dev, run `supabase start` and use
# `supabase status -o env` to read these values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only secret (service role). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

NEXT_PUBLIC_CHILD_EMAIL_DOMAIN=students.summersharp.local

# ElevenLabs text-to-speech (high-quality read-aloud voices). Server-only.
# Get a key at https://elevenlabs.io. ELEVENLABS_VOICE_ID is optional and
# defaults to a warm, clear voice; pick any voice id from your account.
ELEVENLABS_API_KEY=sk_xxx
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Billing (Stripe). Server-only. Keep BILLING_ENABLED=false to stay free.
# Pricing: $5/mo first kid + $2/mo per extra (graduated tiered Stripe price).
BILLING_ENABLED=false
BILLING_LAUNCH_AT=                       # ISO ts; accounts before it are free forever
STRIPE_SECRET_KEY=sk_xxx                 # use sk_test_ in dev, sk_live_ in prod
STRIPE_PRICE_ID=price_xxx                # the graduated tiered price
STRIPE_WEBHOOK_SECRET=whsec_xxx          # from the Stripe webhook endpoint
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin area (/admin). Server-only — never prefix with NEXT_PUBLIC_.
# ADMIN_SECRET signs the admin session cookie; set it to a long random value.
ADMIN_EMAIL=email@netixsolutions.com
ADMIN_PASSWORD=change-me
ADMIN_SECRET=change-me-to-a-long-random-string

# Transactional email (Resend). Server-only. EMAIL_FROM must be a domain VERIFIED
# in Resend. Get a key at https://resend.com.
RESEND_API_KEY=re_xxx
EMAIL_FROM=SummerSharp <noreply@summersharp.app>
